---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import pageData from '../content/settings/faculty.json';

const allFaculty = await getCollection('faculty').catch(() => []);
const faculty = allFaculty.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const allMentors = await getCollection('mentors').catch(() => []);
const mentors = allMentors.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout
  title="師資陣容 | 影視傳播系"
  description="黎明技術學院影視傳播系師資團隊由業界資深工作者組成，涵蓋導演、攝影師、剪輯師、聲音設計等專業領域，提供最貼近產業的教學經驗。"
  keywords="影視傳播系師資,電影系老師,影視製作教授,業師講座,影視系教師陣容"
>

  <section class="pt-40 pb-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-film-gray to-film-black"></div>
    <div class="relative z-10 max-w-7xl mx-auto">
      <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-4">{pageData.hero_subtitle}</p>
      <h1 class="font-display text-5xl md:text-7xl text-white font-bold">{pageData.hero_title}</h1>
    </div>
  </section>

  <!-- 師資介紹 -->
  <section class="py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 reveal">
        <p class="text-film-light/60 max-w-2xl leading-relaxed">{pageData.intro}</p>
      </div>

      {faculty.length === 0 ? (
        <p class="text-film-light/40 text-sm">尚無師資資料，請至後台新增。</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {faculty.map((person, i) => (
            <div class="reveal group border border-white/10 hover:border-film-gold transition-all duration-300 p-8"
                 style={`transition-delay: ${i * 80}ms`}>
              <!-- 照片或首字佔位 -->
              {person.data.photo ? (
                <div class="w-20 h-20 mb-6 overflow-hidden border border-white/20 group-hover:border-film-gold transition-colors">
                  <img
                    src={person.data.photo}
                    alt={person.data.name}
                    class="w-full h-full object-cover"
                  />
                </div>
              ) : (
                <div class="w-20 h-20 bg-film-gray border border-white/20 mb-6 flex items-center justify-center group-hover:border-film-gold transition-colors">
                  <span class="font-display text-2xl text-film-gold/40 group-hover:text-film-gold transition-colors">
                    {person.data.name[0]}
                  </span>
                </div>
              )}

              <h3 class="text-white font-semibold text-lg mb-1 group-hover:text-film-gold transition-colors">
                {person.data.name}
              </h3>
              <p class="text-film-gold text-xs tracking-wide mb-1">{person.data.title}</p>
              <p class="text-film-light/40 text-xs mb-4 border-b border-white/10 pb-4">專長：{person.data.specialty}</p>
              <p class="text-film-light/60 text-sm leading-relaxed">{person.data.bio}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- 業師講座 -->
  <section class="py-24 px-6 bg-film-gray">
    <div class="max-w-7xl mx-auto">
      <!-- 說明文字 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-20">
        <div class="reveal-left">
          <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-4">{pageData.mentors_subtitle}</p>
          <h2 class="font-display text-4xl text-white mb-8">{pageData.mentors_title}</h2>
          <p class="text-film-light/60 leading-relaxed mb-6">{pageData.mentors_p1}</p>
          <p class="text-film-light/60 leading-relaxed">{pageData.mentors_p2}</p>
        </div>
        <div class="reveal-right grid grid-cols-2 gap-4">
          {pageData.mentor_roles.map((role: string) => (
            <div class="border border-white/10 hover:border-film-gold p-4 text-center transition-colors">
              <p class="text-film-light/60 text-sm">{role}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- 業師卡片 -->
      {mentors.length > 0 && (
        <div>
          <h3 class="font-display text-2xl text-white mb-10 reveal">歷屆業師</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
            {mentors.map((mentor, i) => (
              <div class="reveal group border border-white/10 hover:border-film-gold transition-all duration-300 p-6"
                   style={`transition-delay: ${i * 60}ms`}>
                <!-- 照片或首字 -->
                {mentor.data.photo ? (
                  <div class="w-16 h-16 mb-4 overflow-hidden border border-white/20 group-hover:border-film-gold transition-colors">
                    <img src={mentor.data.photo} alt={mentor.data.name} class="w-full h-full object-cover" />
                  </div>
                ) : (
                  <div class="w-16 h-16 bg-film-black border border-white/20 mb-4 flex items-center justify-center group-hover:border-film-gold transition-colors">
                    <span class="font-display text-xl text-film-gold/40 group-hover:text-film-gold transition-colors">
                      {mentor.data.name[0]}
                    </span>
                  </div>
                )}
                <h4 class="text-white font-semibold mb-1 group-hover:text-film-gold transition-colors">
                  {mentor.data.name}
                </h4>
                <p class="text-film-gold text-xs mb-1">{mentor.data.title}</p>
                <p class="text-film-light/40 text-xs mb-3">{mentor.data.specialty}</p>
                {mentor.data.semester && (
                  <span class="text-xs border border-white/20 text-film-light/40 px-2 py-0.5">
                    {mentor.data.semester}
                  </span>
                )}
                <p class="text-film-light/60 text-xs leading-relaxed mt-3">{mentor.data.bio}</p>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

</BaseLayout>
