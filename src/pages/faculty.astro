---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import pageData from '../content/settings/faculty.json';

const allFaculty = await getCollection('faculty').catch(() => []);
const faculty = allFaculty.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const allMentors = await getCollection('mentors').catch(() => []);
const mentors = allMentors.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout
  title="師資陣容 | 影視傳播系"
  description="黎明技術學院影視傳播系師資團隊由業界資深工作者組成，涵蓋導演、攝影師、剪輯師、聲音設計等專業領域，提供最貼近產業的教學經驗。"
  keywords="影視傳播系師資,電影系老師,影視製作教授,業師講座,影視系教師陣容"
>

  <section class="pt-40 pb-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-film-gray to-film-black"></div>
    <div class="relative z-10 max-w-7xl mx-auto">
      <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-4">{pageData.hero_subtitle}</p>
      <h1 class="font-display text-5xl md:text-7xl text-white font-bold">{pageData.hero_title}</h1>
    </div>
  </section>

  <!-- 師資介紹 -->
  <section class="py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 reveal">
        <p class="text-film-light/60 max-w-2xl leading-relaxed">{pageData.intro}</p>
      </div>

      {faculty.length === 0 ? (
        <p class="text-film-light/40 text-sm">尚無師資資料，請至後台新增。</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {faculty.map((person, i) => (
            <div class="reveal group border border-white/10 hover:border-film-gold transition-all duration-300 p-8"
                 style={`transition-delay: ${i * 80}ms`}>
              <!-- 照片或首字佔位 -->
              {person.data.photo ? (
                <div class="w-20 h-20 mb-6 overflow-hidden border border-white/20 group-hover:border-film-gold transition-colors">
                  <img
                    src={person.data.photo}
                    alt={person.data.name}
                    class="w-full h-full object-cover"
                  />
                </div>
              ) : (
                <div class="w-20 h-20 bg-film-gray border border-white/20 mb-6 flex items-center justify-center group-hover:border-film-gold transition-colors">
                  <span class="font-display text-2xl text-film-gold/40 group-hover:text-film-gold transition-colors">
                    {person.data.name[0]}
                  </span>
                </div>
              )}

              <h3 class="text-white font-semibold text-lg mb-1 group-hover:text-film-gold transition-colors">
                {person.data.name}
              </h3>
              <p class="text-film-gold text-xs tracking-wide mb-1">{person.data.title}</p>
              <p class="text-film-light/40 text-xs mb-4 border-b border-white/10 pb-4">專長：{person.data.specialty}</p>
              <p class="text-film-light/60 text-sm leading-relaxed">{person.data.bio}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- 業師講座 -->
  <section class="py-24 px-6 bg-film-gray">
    <div class="max-w-7xl mx-auto">
      <!-- 說明文字 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start mb-16">
        <div class="reveal-left">
          <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-4">{pageData.mentors_subtitle}</p>
          <h2 class="font-display text-4xl text-white mb-8">{pageData.mentors_title}</h2>
          <p class="text-film-light/60 leading-relaxed mb-6">{pageData.mentors_p1}</p>
          <p class="text-film-light/60 leading-relaxed">{pageData.mentors_p2}</p>
        </div>

        <!-- 可點擊的分類標籤 -->
        <div class="reveal-right grid grid-cols-2 gap-4">
          {pageData.mentor_roles.map((role: string) => (
            <button
              class="mentor-filter-btn border border-white/10 hover:border-film-gold p-4 text-center transition-all duration-300 cursor-pointer group"
              data-role={role}
            >
              <p class="text-film-light/60 text-sm group-hover:text-film-gold transition-colors">{role}</p>
              <p class="text-film-gold/0 text-xs mt-1 group-hover:text-film-gold/60 transition-colors tracking-widest">點擊篩選</p>
            </button>
          ))}
        </div>
      </div>

      <!-- 業師卡片區 -->
      {mentors.length > 0 && (
        <div id="mentors-section">
          <div class="flex items-center justify-between mb-8">
            <h3 class="font-display text-2xl text-white">
              歷屆業師
              <span id="active-filter-label" class="text-film-gold text-lg ml-3 hidden"></span>
            </h3>
            <button id="clear-filter" class="hidden text-xs text-film-light/40 hover:text-film-gold tracking-widest uppercase transition-colors">
              ✕ 清除篩選
            </button>
          </div>
          <div id="mentor-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
            {mentors.map((mentor, i) => (
              <div
                class="mentor-card reveal group border border-white/10 hover:border-film-gold transition-all duration-300 p-6"
                data-specialty={mentor.data.specialty}
                style={`transition-delay: ${i * 60}ms`}
              >
                {mentor.data.photo ? (
                  <div class="w-full aspect-square mb-4 overflow-hidden border border-white/20 group-hover:border-film-gold transition-colors">
                    <img src={mentor.data.photo} alt={mentor.data.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                  </div>
                ) : (
                  <div class="w-full aspect-square bg-film-black border border-white/20 mb-4 flex items-center justify-center group-hover:border-film-gold transition-colors">
                    <span class="font-display text-5xl text-film-gold/20 group-hover:text-film-gold/50 transition-colors">
                      {mentor.data.name[0]}
                    </span>
                  </div>
                )}
                <h4 class="text-white font-semibold mb-1 group-hover:text-film-gold transition-colors">
                  {mentor.data.name}
                </h4>
                <p class="text-film-gold text-xs mb-1">{mentor.data.title}</p>
                <p class="text-film-light/40 text-xs mb-3 border-b border-white/10 pb-3">{mentor.data.specialty}</p>
                <p class="text-film-light/60 text-xs leading-relaxed">{mentor.data.bio}</p>
                {mentor.data.semester && (
                  <span class="inline-block mt-3 text-xs border border-white/20 text-film-light/40 px-2 py-0.5">
                    {mentor.data.semester}
                  </span>
                )}
              </div>
            ))}
          </div>
          <p id="no-result" class="hidden text-film-light/40 text-sm mt-4">此分類目前尚無業師資料。</p>
        </div>
      )}
    </div>
  </section>

  <script>
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.mentor-filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.mentor-card');
    const clearBtn = document.getElementById('clear-filter');
    const filterLabel = document.getElementById('active-filter-label');
    const noResult = document.getElementById('no-result');
    let activeRole = '';

    function applyFilter(role: string) {
      activeRole = role;
      let visible = 0;

      cards.forEach(card => {
        const specialty = card.dataset.specialty ?? '';
        const match = !role || specialty.includes(role);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      // 更新 UI 狀態
      filterBtns.forEach(btn => {
        const isActive = btn.dataset.role === role;
        btn.classList.toggle('border-film-gold', isActive);
        btn.classList.toggle('bg-film-gold/10', isActive);
        btn.querySelector('p')?.classList.toggle('text-film-gold', isActive);
      });

      if (filterLabel) {
        filterLabel.textContent = role ? `— ${role}` : '';
        filterLabel.classList.toggle('hidden', !role);
      }
      clearBtn?.classList.toggle('hidden', !role);
      noResult?.classList.toggle('hidden', visible > 0 || !role);
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const role = btn.dataset.role ?? '';
        applyFilter(activeRole === role ? '' : role); // 再點同一個取消篩選
      });
    });

    clearBtn?.addEventListener('click', () => applyFilter(''));
  </script>

</BaseLayout>
