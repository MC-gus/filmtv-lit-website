---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../content/settings/admission.json';
---

<BaseLayout
  title={`${data.hero_title} | 影視傳播系`}
  description="黎明技術學院影視傳播系招生資訊，包含個人申請、繁星推薦、考試分發、四技二專統測等入學管道，歡迎對影視創作有熱情的你加入我們。"
  keywords="影視傳播系招生,電影系入學,影視系申請,黎明技術學院招生,影視系考試,統測影視傳播"
>

  <section class="pt-40 pb-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-film-gray to-film-black"></div>
    <div class="relative z-10 max-w-7xl mx-auto">
      <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-4">{data.hero_subtitle}</p>
      <h1 class="font-display text-5xl md:text-7xl text-white font-bold">{data.hero_title}</h1>
    </div>
  </section>

  <section class="py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 reveal">
        <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-4">How to Apply</p>
        <h2 class="font-display text-4xl text-white mb-6">入學管道</h2>
        <p class="text-film-light/60 max-w-2xl leading-relaxed">{data.intro}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {data.channels.map((channel, i) => (
          <div class="reveal border border-white/10 hover:border-film-gold group transition-colors duration-300 p-8"
               style={`transition-delay: ${i * 100}ms`}>
            <div class="flex items-start justify-between mb-6">
              <h3 class="font-display text-xl text-white group-hover:text-film-gold transition-colors">{channel.title}</h3>
              <span class="text-xs border border-film-gold/40 text-film-gold px-3 py-1 shrink-0 ml-4">{channel.period}</span>
            </div>
            <p class="text-film-light/60 text-sm leading-relaxed mb-6">{channel.desc}</p>
            <div class="flex items-center gap-2 flex-wrap">
              {channel.steps.map((step, si) => (
                <>
                  <span class="text-xs text-film-light/60 bg-white/5 px-3 py-1">{step}</span>
                  {si < channel.steps.length - 1 && <span class="text-film-gold/40 text-xs">→</span>}
                </>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-film-gray">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16 reveal">
        <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-4">{data.faq_subtitle}</p>
        <h2 class="font-display text-4xl text-white">{data.faq_title}</h2>
      </div>
      <div class="space-y-4">
        {data.faqs.map((faq, i) => (
          <div class="reveal border border-white/10 hover:border-film-gold/50 transition-colors p-8"
               style={`transition-delay: ${i * 80}ms`}>
            <h3 class="text-white font-semibold mb-3 flex items-start gap-3">
              <span class="text-film-gold shrink-0">Q</span>{faq.q}
            </h3>
            <p class="text-film-light/60 text-sm leading-relaxed pl-6">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6">
    <div class="max-w-3xl mx-auto text-center reveal">
      <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-6">{data.contact_subtitle}</p>
      <h2 class="font-display text-4xl text-white mb-8">{data.contact_title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 text-left">
        <div class="border border-white/10 p-6">
          <p class="text-film-gold text-xs tracking-widest uppercase mb-2">地址</p>
          <p class="text-white text-sm">{data.address}</p>
        </div>
        <div class="border border-white/10 p-6">
          <p class="text-film-gold text-xs tracking-widest uppercase mb-2">電話</p>
          <p class="text-white text-sm">{data.phone}</p>
        </div>
        <div class="border border-white/10 p-6">
          <p class="text-film-gold text-xs tracking-widest uppercase mb-2">Email</p>
          <p class="text-white text-sm">{data.email}</p>
        </div>
      </div>
      <a href={`mailto:${data.email}`}
        class="inline-block px-12 py-5 bg-film-gold text-film-black font-semibold text-sm tracking-widest uppercase hover:bg-white transition-colors duration-300">
        寄信給我們
      </a>
    </div>
  </section>

</BaseLayout>
