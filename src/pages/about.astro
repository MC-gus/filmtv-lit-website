---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../content/settings/about.json';
---

<BaseLayout
  title={`${data.hero_title} | 影視傳播系`}
  description="了解黎明技術學院影視傳播系的辦學理念、四大教育目標與發展歷史。超過 20 年培育影視人才，持續深化產學合作，連結創作與產業。"
  keywords="黎明技術學院影視傳播系介紹,影視系辦學理念,電影系特色,影視傳播系歷史"
>

  <section class="pt-40 pb-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-film-gray to-film-black"></div>
    <div class="relative z-10 max-w-7xl mx-auto">
      <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-4">{data.hero_subtitle}</p>
      <h1 class="font-display text-5xl md:text-7xl text-white font-bold">{data.hero_title}</h1>
    </div>
  </section>

  <!-- 系所理念 -->
  <section class="py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div class="reveal-left">
        <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-6">{data.philosophy_subtitle}</p>
        <h2 class="font-display text-4xl text-white mb-8 leading-tight">{data.philosophy_title}</h2>
        <p class="text-film-light/60 leading-relaxed mb-6">{data.philosophy_p1}</p>
        <p class="text-film-light/60 leading-relaxed mb-6">{data.philosophy_p2}</p>
        <p class="text-film-light/60 leading-relaxed">{data.philosophy_p3}</p>
      </div>
      <div class="reveal-right relative">
        <div class="aspect-[4/3] bg-film-gray border border-white/10 flex items-center justify-center">
          <div class="text-center px-8">
            <div class="font-display text-8xl text-film-gold/20 font-bold leading-none mb-4">影</div>
            <p class="text-film-light/40 text-sm tracking-widest">FILM & TELEVISION</p>
          </div>
        </div>
        <div class="absolute -top-4 -right-4 w-32 h-32 border border-film-gold/30"></div>
        <div class="absolute -bottom-4 -left-4 w-32 h-32 border border-film-gold/30"></div>
      </div>
    </div>
  </section>

  <!-- 教育目標 -->
  <section class="py-24 px-6 bg-film-gray">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 reveal">
        <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-4">{data.goals_subtitle}</p>
        <h2 class="font-display text-4xl text-white">{data.goals_title}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {data.goals.map((item, i) => (
          <div class="reveal border border-white/10 hover:border-film-gold group transition-colors duration-300 p-8"
               style={`transition-delay: ${i * 100}ms`}>
            <div class="flex items-start gap-6">
              <span class="font-display text-4xl text-film-gold/30 font-bold leading-none group-hover:text-film-gold/60 transition-colors">
                {item.num}
              </span>
              <div>
                <h3 class="text-white font-semibold text-lg mb-3 group-hover:text-film-gold transition-colors">{item.title}</h3>
                <p class="text-film-light/60 text-sm leading-relaxed">{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 歷史沿革 -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16 reveal">
        <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-4">{data.history_subtitle}</p>
        <h2 class="font-display text-4xl text-white">{data.history_title}</h2>
      </div>
      <div class="relative">
        <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-white/10 transform md:-translate-x-1/2"></div>
        <div class="space-y-12">
          {data.history.map((item, i) => (
            <div class="reveal relative flex flex-col md:flex-row gap-8">
              <div class={`md:w-1/2 ${i % 2 === 0 ? 'md:text-right md:pr-12' : 'md:text-left md:pl-12 md:ml-auto'}`}>
                <div class="text-film-gold font-display text-2xl font-bold mb-2">{item.year}</div>
                <h3 class="text-white font-semibold mb-2">{item.event}</h3>
                <p class="text-film-light/60 text-sm leading-relaxed">{item.desc}</p>
              </div>
              <div class="hidden md:block absolute left-1/2 top-2 w-3 h-3 bg-film-gold rounded-full transform -translate-x-1/2 border-2 border-film-black"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
