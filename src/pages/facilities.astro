---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../content/settings/facilities.json';
---

<BaseLayout title={`${data.hero_title} | 影視傳播系`}>

  <section class="pt-40 pb-20 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-film-gray to-film-black"></div>
    <div class="relative z-10 max-w-7xl mx-auto">
      <p class="text-film-gold text-xs tracking-[0.4em] uppercase mb-4">{data.hero_subtitle}</p>
      <h1 class="font-display text-5xl md:text-7xl text-white font-bold">{data.hero_title}</h1>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-7xl mx-auto reveal">
      <p class="text-film-light/60 max-w-3xl leading-relaxed text-lg">{data.intro}</p>
    </div>
  </section>

  <section class="py-12 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {data.facilities.map((item, i) => (
        <div class="reveal border border-white/10 hover:border-film-gold group transition-colors duration-300 p-8"
             style={`transition-delay: ${i * 80}ms`}>
          <h3 class="font-display text-xl text-white mb-4 group-hover:text-film-gold transition-colors">{item.name}</h3>
          <p class="text-film-light/60 text-sm leading-relaxed mb-6">{item.desc}</p>
          <div class="flex flex-wrap gap-2">
            {item.tags.map(tag => (
              <span class="text-xs border border-white/20 text-film-light/50 px-3 py-1 group-hover:border-film-gold/40 group-hover:text-film-gold transition-colors">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="py-24 px-6 bg-film-gray">
    <div class="max-w-3xl mx-auto text-center reveal">
      <h2 class="font-display text-3xl text-white mb-6">{data.cta_title}</h2>
      <p class="text-film-light/60 mb-10 leading-relaxed">{data.cta_desc}</p>
      <a href="/admission" class="inline-block px-10 py-4 bg-film-gold text-film-black font-semibold text-sm tracking-widest uppercase hover:bg-white transition-colors duration-300">
        聯絡我們
      </a>
    </div>
  </section>

</BaseLayout>
